{
  "name": "kreis-web-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.ts",
    "dev:api": "tsx watch apps/api/src/platform/server.ts",
    "build": "tsc -b && vite build --config apps/web/vite.config.ts",
    "typecheck": "tsc -b",
    "typecheck:api": "tsc -p apps/api/tsconfig.json",
    "preview": "vite preview --config apps/web/vite.config.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
