{
    "name": "kreis-web-app",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --config apps/web/vite.config.ts",
        "dev:api": "tsx watch apps/api/src/platform/server.ts",
        "build": "npm run build:web",
        "build:web": "tsc -p apps/web/tsconfig.json --noEmit && vite build --config apps/web/vite.config.ts",
        "build:full": "tsc -b && vite build --config apps/web/vite.config.ts",
        "lint": "eslint .",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "test": "vitest run --config vitest.config.ts --configLoader runner --passWithNoTests",
        "test:watch": "vitest --config vitest.config.ts --configLoader runner",
        "typecheck": "tsc -b",
        "typecheck:web": "tsc -p apps/web/tsconfig.json --noEmit",
        "verify:auth-layout": "node apps/web/scripts/verify-auth-layout.mjs",
        "pretypecheck:api": "npm run db:generate",
        "typecheck:api": "tsc -p apps/api/tsconfig.json",
        "preview": "vite preview --config apps/web/vite.config.ts",
        "prestart:api": "npm run db:generate",
        "start:api": "tsx apps/api/src/platform/server.ts",
        "predev:api": "npm run db:generate",
        "db:generate": "prisma generate"
    },
    "dependencies": {
        "@phosphor-icons/react": "^2.1.10",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@solar-icons/react": "1.1.0",
        "@supabase/supabase-js": "^2.106.1",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^5.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "google-auth-library": "^10.7.0",
        "helmet": "^8.1.0",
        "ioredis": "^5.11.1",
        "multer": "^2.1.1",
        "pg": "^8.21.0",
        "prisma": "^7.8.0",
        "process": "^0.11.10",
        "rate-limit-redis": "^5.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router": "7.15.1",
        "sharp": "^0.35.1",
        "tsx": "^4.22.4",
        "vite": "^7.0.0",
        "ws": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@tailwindcss/vite": "^4.2.4",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "10.4.0",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "globals": "17.6.0",
        "jsdom": "29.1.1",
        "prettier": "3.8.3",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "8.59.3",
        "vite-plugin-pwa": "^1.3.0",
        "vitest": "4.1.6"
    }
}
