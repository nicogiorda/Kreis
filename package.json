{
  "name": "kreis-web-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.ts",
    "dev:api": "tsx watch apps/api/src/platform/server.ts",
    "build": "tsc -b && vite build --config apps/web/vite.config.ts",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --config vitest.config.ts --configLoader runner --passWithNoTests",
    "test:watch": "vitest --config vitest.config.ts --configLoader runner",
    "typecheck": "tsc -b",
    "typecheck:api": "tsc -p apps/api/tsconfig.json",
    "preview": "vite preview --config apps/web/vite.config.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^6.19.3",
    "@solar-icons/react": "1.1.0",
    "@supabase/supabase-js": "^2.106.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "env": "^0.0.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "process": "^0.11.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "7.15.1",
    "vite": "^7.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "10.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "4.1.6"
  }
}
