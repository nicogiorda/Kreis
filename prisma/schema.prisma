generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model users {
  id      String   @id @db.Uuid
  email   String?  @db.VarChar(255)
  usuario usuario?

  @@schema("auth")
}

model facultad {
  id_facultad BigInt    @id @default(autoincrement())
  nombre      String    @unique
  usuario     usuario[]

  @@schema("public")
}

model usuario {
  legajo         Int              @id
  auth_id        String           @unique @db.Uuid
  nombre         String
  apellido       String
  id_facultad    BigInt
  rol            user_role        @default(Estudiante)
  verificado     Boolean          @default(false)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  comentario     comentario[]
  comunidad      comunidad[]
  evento         evento[]
  post           post[]
  user_comunidad user_comunidad[]
  user_evento    user_evento[]
  authUser       users            @relation(fields: [auth_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_usuario_auth")
  facultad       facultad         @relation(fields: [id_facultad], references: [id_facultad], onDelete: Cascade, onUpdate: NoAction, map: "fk_usuario_facultad")
  usuario_topico usuario_topico[]

  @@schema("public")
}

model topico {
  id_topico        BigInt             @id @default(autoincrement())
  topico           String             @unique
  comunidad_topico comunidad_topico[]
  evento_topico    evento_topico[]
  usuario_topico   usuario_topico[]

  @@schema("public")
}

model usuario_topico {
  legajo    Int
  id_topico BigInt
  topico    topico  @relation(fields: [id_topico], references: [id_topico], onDelete: Cascade, onUpdate: NoAction, map: "fk_usuario_topico_topico")
  usuario   usuario @relation(fields: [legajo], references: [legajo], onDelete: Cascade, onUpdate: NoAction, map: "fk_usuario_topico_usuario")

  @@id([legajo, id_topico])
  @@schema("public")
}

model evento {
  id_evento     BigInt             @id @default(autoincrement())
  legajo        Int
  nombre        String
  ubicacion     String?
  fecha_inicio  DateTime           @db.Timestamptz(6)
  descripcion   String?
  estado        publication_status @default(Pendiente)
  created_at    DateTime           @default(now()) @db.Timestamptz(6)
  imagen_url    String?
  usuario       usuario            @relation(fields: [legajo], references: [legajo], onDelete: Cascade, onUpdate: NoAction, map: "fk_evento_creador")
  evento_topico evento_topico[]
  user_evento   user_evento[]

  @@schema("public")
}

model user_evento {
  legajo    Int
  id_evento BigInt
  evento    evento  @relation(fields: [id_evento], references: [id_evento], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_evento_evento")
  usuario   usuario @relation(fields: [legajo], references: [legajo], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_evento_usuario")

  @@id([legajo, id_evento])
  @@schema("public")
}

model evento_topico {
  id_evento BigInt
  id_topico BigInt
  evento    evento @relation(fields: [id_evento], references: [id_evento], onDelete: Cascade, onUpdate: NoAction, map: "fk_evento_topico_evento")
  topico    topico @relation(fields: [id_topico], references: [id_topico], onDelete: Cascade, onUpdate: NoAction, map: "fk_evento_topico_topico")

  @@id([id_evento, id_topico])
  @@schema("public")
}

model comunidad {
  id_comunidad     BigInt             @id @default(autoincrement())
  legajo           Int
  nombre           String
  descripcion      String?
  estado           publication_status @default(Pendiente)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  usuario          usuario            @relation(fields: [legajo], references: [legajo], onDelete: Cascade, onUpdate: NoAction, map: "fk_comunidad_creador")
  comunidad_topico comunidad_topico[]
  post             post[]
  user_comunidad   user_comunidad[]

  @@schema("public")
}

model user_comunidad {
  legajo       Int
  id_comunidad BigInt
  comunidad    comunidad @relation(fields: [id_comunidad], references: [id_comunidad], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_comunidad_comunidad")
  usuario      usuario   @relation(fields: [legajo], references: [legajo], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_comunidad_usuario")

  @@id([legajo, id_comunidad])
  @@schema("public")
}

model comunidad_topico {
  id_comunidad BigInt
  id_topico    BigInt
  comunidad    comunidad @relation(fields: [id_comunidad], references: [id_comunidad], onDelete: Cascade, onUpdate: NoAction, map: "fk_comunidad_topico_comunidad")
  topico       topico    @relation(fields: [id_topico], references: [id_topico], onDelete: Cascade, onUpdate: NoAction, map: "fk_comunidad_topico_topico")

  @@id([id_comunidad, id_topico])
  @@schema("public")
}

model post {
  id_post      BigInt       @id @default(autoincrement())
  legajo       Int
  id_comunidad BigInt
  cuerpo       String
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  comentario   comentario[]
  comunidad    comunidad    @relation(fields: [id_comunidad], references: [id_comunidad], onDelete: Cascade, onUpdate: NoAction, map: "fk_post_comunidad")
  usuario      usuario      @relation(fields: [legajo], references: [legajo], onDelete: Cascade, onUpdate: NoAction, map: "fk_post_usuario")

  @@schema("public")
}

model comentario {
  id_comentario BigInt       @id @default(autoincrement())
  legajo        Int
  id_post       BigInt
  cuerpo        String
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  id_padre      BigInt?
  post          post         @relation(fields: [id_post], references: [id_post], onDelete: Cascade, onUpdate: NoAction, map: "fk_comentario_post")
  usuario       usuario      @relation(fields: [legajo], references: [legajo], onDelete: Cascade, onUpdate: NoAction, map: "fk_comentario_usuario")
  padre         comentario?  @relation("ComentarioRespuestas", fields: [id_padre], references: [id_comentario], onDelete: Cascade, onUpdate: NoAction, map: "comentario_id_padre_fkey")
  respuestas    comentario[] @relation("ComentarioRespuestas")

  @@index([id_post, id_padre], map: "comentario_id_post_id_padre_idx")
  @@index([id_padre], map: "comentario_id_padre_idx")
  @@schema("public")
}

enum publication_status {
  Pendiente
  Aceptado
  Rechazado

  @@schema("public")
}

enum user_role {
  Estudiante
  Moderador
  Administrador

  @@schema("public")
}
