{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.shared.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["shared/**/*.ts"]
}
